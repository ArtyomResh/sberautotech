    "babel-eslint": "10.1.0",
    "eslint": "7.18.0",
    "eslint-plugin-react": "7.22.0",
    "eslint-plugin-react-hooks": "4.2.0",
    "npm-run-all": "4.1.5",
    "stylelint": "13.12.0",
    "stylelint-a11y": "1.2.3",
    "stylelint-declaration-block-no-ignored-properties": "2.3.0",
    "stylelint-declaration-use-variable": "1.7.2",
